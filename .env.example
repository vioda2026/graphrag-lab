# LLM / Embedding API
OPENAI_BASE_URL=https://api.edgefn.net/v1
OPENAI_API_KEY=your_api_key_here

# Default generation model for chat/completion
OPENAI_MODEL=Qwen3-235B-A22B-2507

# Optional alternatives
ALT_CHAT_MODELS=MiniMax-M2.5,DeepSeek-V3.2,GLM-4.7,GLM-5

# Embedding model
EMBEDDING_MODEL=BAAI/bge-m3
